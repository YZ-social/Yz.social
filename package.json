{
  "name": "civildefense.io",
  "description": "Browser app to safely share live sightings on a map.",
  "version": "0.0.56",
  "keywords": [
    "map",
    "browser",
    "alert"
  ],
  "scripts": {
    "start": "npm stop; npm run shared",
    "stop": "pkill yz.social",
    "local": "node ./app.js",
    "shared": "node ./app.js --externalBaseURL https://ki1r0y.com/kdht",
    "withoutExternal": "npm run local",
    "withoutPortals": "node ./app.js --nPortals 0"
  },
  "type": "module",
  "dependencies": {
    "@yz-social/kdht": "^0.1.40",
    "@yz-social/webrtc": "^0.1.8",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "express-ws": "^5.0.2",
    "leaflet": "^1.9.4",
    "minidenticons": "^4.2.1",
    "morgan": "^1.10.1",
    "node-turn": "^0.0.6",
    "uuid": "^13.0.0",
    "ws": "^8.18.3",
    "yargs": "^18.0.0"
  },
  "overrides": {
    "log4js": "^6.9.1"
  }
}
